rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to fetch profile safely
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function profileExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAuthorized() {
      return isSignedIn() && 
             profileExists() && 
             getProfile().get('disabled', false) == false;
    }

    function isAdmin() {
      return isSignedIn() && 
             profileExists() && 
             getProfile().get('role', '') == 'admin';
    }

    function isContactAccepted(senderId, receiverId, pitchId) {
      let reqId = senderId + "_" + receiverId + "_" + pitchId;
      return exists(/databases/$(database)/documents/contactRequests/$(reqId)) && 
             get(/databases/$(database)/documents/contactRequests/$(reqId)).data.status == 'accepted';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pitches/{pitchId} {
      allow read: if isSignedIn(); // Broaden read for authorized exploration
      allow create: if isAuthorized() && (getProfile().get('role', '') == 'startup' || isAdmin()) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthorized() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAuthorized() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /interests/{interestId} {
      allow read: if isAuthorized() && (
        resource.data.investorId == request.auth.uid || 
        resource.data.startupOwnerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthorized() && (getProfile().get('role', '') == 'investor' || isAdmin()) && request.resource.data.investorId == request.auth.uid;
      allow delete: if isAuthorized() && (resource.data.investorId == request.auth.uid || isAdmin());
    }

    match /favorites/{favoriteId} {
      allow read: if isAuthorized() && (resource.data.investorId == request.auth.uid || isAdmin());
      allow create: if isAuthorized() && (getProfile().get('role', '') == 'investor' || isAdmin()) && request.resource.data.investorId == request.auth.uid;
      allow delete: if isAuthorized() && (resource.data.investorId == request.auth.uid || isAdmin());
    }

    match /contactRequests/{requestId} {
      allow list: if isAuthorized() && (
        request.query.filters.senderId == request.auth.uid || 
        request.query.filters.receiverId == request.auth.uid ||
        isAdmin()
      );
      allow get: if isAuthorized() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthorized() && (getProfile().get('role', '') == 'investor' || isAdmin()) && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthorized() && (
        (resource.data.receiverId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
      allow delete: if isAuthorized() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    match /messages/{messageId} {
      allow create: if isAuthorized() && 
        request.resource.data.senderId == request.auth.uid &&
        isContactAccepted(request.resource.data.senderId, request.resource.data.receiverId, request.resource.data.pitchId);
      
      allow list: if isAuthorized() && (
        request.query.filters.senderId == request.auth.uid || 
        request.query.filters.receiverId == request.auth.uid ||
        isAdmin()
      );
      
      allow get: if isAuthorized() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );

      allow update: if isAuthorized() && (
        (resource.data.receiverId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      // Relax rules to allow users to see their own notifications without full profile synchronization.
      allow list: if isSignedIn() && (request.query.filters.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /logs/{logId} {
      allow list: if isAdmin();
      allow get: if isAdmin();
      allow create: if isAuthorized();
    }

    match /deleteRequests/{requestId} {
      allow list: if isAdmin() || (isAuthorized() && request.query.filters.userId == request.auth.uid);
      allow get: if isAdmin() || (isAuthorized() && resource.data.userId == request.auth.uid);
      allow create: if isAuthorized() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
