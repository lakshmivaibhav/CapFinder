
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getProfile().role == role;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /pitches/{pitchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && hasRole('startup') && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /interests/{interestId} {
      // Allow listing interests where the user is either the investor or the startup owner.
      // Split into separate explicit list rules to satisfy query optimization.
      allow list: if isSignedIn() && (
        (request.query.limit <= 500) && (
          resource.data.investorId == request.auth.uid || 
          resource.data.startupOwnerId == request.auth.uid
        )
      );
      
      allow get: if isSignedIn() && (
        resource.data.investorId == request.auth.uid || 
        resource.data.startupOwnerId == request.auth.uid
      );
      
      allow create: if isSignedIn() && hasRole('investor') && request.resource.data.investorId == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.investorId == request.auth.uid;
    }

    match /favorites/{favoriteId} {
      allow list: if isSignedIn() && resource.data.investorId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.investorId == request.auth.uid;
      allow create: if isSignedIn() && hasRole('investor') && request.resource.data.investorId == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.investorId == request.auth.uid;
    }
  }
}
