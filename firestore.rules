
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /pitches/{pitchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && hasRole('startup') && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /interests/{interestId} {
      // Investors can list their own interests, Startups can list interests in their pitches
      allow list: if isSignedIn() && (hasRole('investor') || hasRole('startup'));
      allow get: if isSignedIn() && (resource.data.investorId == request.auth.uid || resource.data.startupOwnerId == request.auth.uid);
      
      // Only investors can express interest
      allow create: if isSignedIn() && hasRole('investor') && request.resource.data.investorId == request.auth.uid;
      
      // Interests are generally immutable once expressed
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.investorId == request.auth.uid;
    }
  }
}
