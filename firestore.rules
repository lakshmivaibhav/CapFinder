
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to fetch profile safely
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function profileExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAuthorized() {
      return isSignedIn() && 
             profileExists() && 
             getProfile().get('disabled', false) == false;
    }

    function isAdmin() {
      return isSignedIn() && 
             profileExists() && 
             getProfile().get('role', '') == 'admin';
    }

    function isParticipant(data) {
      return request.auth.uid == data.senderId || request.auth.uid == data.receiverId;
    }

    match /users/{userId} {
      // Allow read for landing page stats and profile discovery
      allow read: if isSignedIn() || true; 
      
      // Allow creation only for self, with restricted initial fields
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    request.resource.data.get('role', 'startup') in ['startup', 'investor'] &&
                    request.resource.data.get('verified', false) == false &&
                    request.resource.data.get('disabled', false) == false;
      
      // Only owner can update their profile, but cannot change sensitive fields (role, verified, disabled)
      // Admins have full override
      allow update: if (isSignedIn() && request.auth.uid == userId && 
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'verified', 'disabled', 'id'])) || 
                    isAdmin();
      
      allow delete: if isAdmin();
    }

    match /pitches/{pitchId} {
      // Public read for marketplace, create for authenticated founders
      allow read: if isSignedIn() || true; 
      allow create: if isAuthorized() && request.resource.data.ownerId == request.auth.uid;
      
      // Only owner or admin can update/delete
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /interests/{interestId} {
      // Only involved parties or admin can read/list interests
      allow read: if isSignedIn() && (
        resource.data.investorId == request.auth.uid || 
        resource.data.startupOwnerId == request.auth.uid || 
        isAdmin()
      );
      allow list: if isSignedIn() && (
        request.query.filters.investorId == request.auth.uid || 
        request.query.filters.startupOwnerId == request.auth.uid || 
        isAdmin()
      );
      
      allow create: if isAuthorized() && (getProfile().get('role', '') == 'investor' || isAdmin()) && request.resource.data.investorId == request.auth.uid;
      allow delete: if isAuthorized() && (resource.data.investorId == request.auth.uid || isAdmin());
    }

    match /favorites/{favoriteId} {
      // Favorites are private to the investor
      allow list: if isSignedIn() && request.query.filters.investorId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.investorId == request.auth.uid;
      allow create: if isAuthorized() && request.resource.data.investorId == request.auth.uid;
      allow delete: if isAuthorized() && resource.data.investorId == request.auth.uid;
    }

    match /contactRequests/{requestId} {
      // Only sender or receiver can see requests
      allow read: if isSignedIn() && (
        isParticipant(resource.data) || 
        isAdmin()
      );
      allow list: if isSignedIn() && (
        request.query.filters.senderId == request.auth.uid || 
        request.query.filters.receiverId == request.auth.uid || 
        isAdmin()
      );
      
      allow create: if isAuthorized() && (getProfile().get('role', '') == 'investor' || isAdmin()) && request.resource.data.senderId == request.auth.uid;
      
      // Receiver can update status, Admin can do anything
      allow update: if isAuthorized() && (
        (resource.data.receiverId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
      
      allow delete: if isAuthorized() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    match /messages/{messageId} {
      // Strict participant-only access for private messaging
      allow create: if isAuthorized() && 
        request.resource.data.senderId == request.auth.uid;
      
      allow list: if isAuthorized() && (
        request.query.filters.senderId == request.auth.uid || 
        request.query.filters.receiverId == request.auth.uid ||
        isAdmin()
      );
      
      allow get: if isAuthorized() && (
        isParticipant(resource.data) || 
        isAdmin()
      );

      // Only receiver can mark as read
      allow update: if isAuthorized() && (
        (resource.data.receiverId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /deleteRequests/{requestId} {
      // Requests visible to owner and admins
      allow list: if isAdmin() || (isAuthorized() && request.query.filters.userId == request.auth.uid);
      allow get: if isAdmin() || (isAuthorized() && resource.data.userId == request.auth.uid);
      allow create: if isAuthorized() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
