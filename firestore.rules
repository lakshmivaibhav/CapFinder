
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function profileExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && profileExists() && getProfile().get('role', '') == 'admin';
    }

    function isAuthorized() {
      return isSignedIn() && profileExists() && getProfile().get('disabled', false) == false;
    }

    function hasRole(role) {
      return isAuthorized() && getProfile().get('role', '') == role;
    }

    function isContactAccepted(senderId, receiverId, pitchId) {
      let reqId = senderId + "_" + receiverId + "_" + pitchId;
      return exists(/databases/$(database)/documents/contactRequests/$(reqId)) && 
             get(/databases/$(database)/documents/contactRequests/$(reqId)).data.status == 'accepted';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pitches/{pitchId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && (getProfile().get('role', '') == 'startup' || getProfile().get('role', '') == 'admin') && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthorized() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAuthorized() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /interests/{interestId} {
      allow read: if isAuthorized() && (
        resource.data.investorId == request.auth.uid || 
        resource.data.startupOwnerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthorized() && (getProfile().get('role', '') == 'investor' || getProfile().get('role', '') == 'admin') && request.resource.data.investorId == request.auth.uid;
      allow delete: if isAuthorized() && (resource.data.investorId == request.auth.uid || isAdmin());
    }

    match /favorites/{favoriteId} {
      allow read: if isAuthorized() && (resource.data.investorId == request.auth.uid || isAdmin());
      allow create: if isAuthorized() && (getProfile().get('role', '') == 'investor' || getProfile().get('role', '') == 'admin') && request.resource.data.investorId == request.auth.uid;
      allow delete: if isAuthorized() && (resource.data.investorId == request.auth.uid || isAdmin());
    }

    match /contactRequests/{requestId} {
      allow read: if isAuthorized() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthorized() && (getProfile().get('role', '') == 'investor' || getProfile().get('role', '') == 'admin') && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthorized() && (
        (resource.data.receiverId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
      allow delete: if isAuthorized() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    match /messages/{messageId} {
      allow create: if isAuthorized() && 
        request.resource.data.senderId == request.auth.uid &&
        isContactAccepted(request.resource.data.senderId, request.resource.data.receiverId, request.resource.data.pitchId);
      
      allow read: if isAuthorized();

      allow update: if isAuthorized() && (
        (resource.data.receiverId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthorized();
    }

    match /deleteRequests/{requestId} {
      // Prioritize admin access to avoid query evaluation conflicts with per-document owner rules
      allow read: if isAdmin() || (isAuthorized() && resource.data.userId == request.auth.uid);
      allow create: if isAuthorized() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
