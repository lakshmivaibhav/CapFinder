
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getProfile().role == role;
    }

    function isContactAccepted(senderId, receiverId, pitchId) {
      // Deterministic ID pattern: senderId_receiverId_pitchId
      let reqId = senderId + "_" + receiverId + "_" + pitchId;
      return exists(/databases/$(database)/documents/contactRequests/$(reqId)) && 
             get(/databases/$(database)/documents/contactRequests/$(reqId)).data.status == 'accepted';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /pitches/{pitchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && hasRole('startup') && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /interests/{interestId} {
      allow read: if isSignedIn() && (
        resource.data.investorId == request.auth.uid || 
        resource.data.startupOwnerId == request.auth.uid
      );
      allow create: if isSignedIn() && hasRole('investor') && request.resource.data.investorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.investorId == request.auth.uid;
    }

    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && resource.data.investorId == request.auth.uid;
      allow create: if isSignedIn() && hasRole('investor') && request.resource.data.investorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.investorId == request.auth.uid;
    }

    match /contactRequests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      allow create: if isSignedIn() && hasRole('investor') && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.receiverId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
      );
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow create: if isSignedIn() && 
        request.resource.data.senderId == request.auth.uid &&
        isContactAccepted(request.resource.data.senderId, request.resource.data.receiverId, request.resource.data.pitchId);
      
      allow read: if isSignedIn();

      allow update: if isSignedIn() && 
        resource.data.receiverId == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}
